# Required for daily recommendations. Menu collection works without it.
OPENAI_API_KEY=

# Cheap default for the small structured assessment task.
OPENAI_MODEL=gpt-5.4-nano

# Enables the unlinked /admin panel. Use at least 16 characters.
ADMIN_PASSWORD=

# Use a bare public hostname in production to enable automatic HTTPS.
SITE_ADDRESS=http://localhost
